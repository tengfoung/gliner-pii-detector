{
  "info": {
    "name": "GLiNER PII Detector API",
    "description": "API collection for detecting PII (Personally Identifiable Information) in text using GLiNER model. Supports financial, trading, and personal entity types.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "gliner-pii-detector"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/api/v1/pii/health",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "v1", "pii", "health"]
        },
        "description": "Check if the PII Detection Service is running"
      },
      "response": []
    },
    {
      "name": "Get All Entity Types",
      "request": {
        "method": "GET",
