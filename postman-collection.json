    {
      "name": "Detect PII - Financial Example",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Please transfer $5000 from account 123456789 to routing number 021000021. My credit card 4532-1234-5678-9010 can be used for backup.\",\n  \"entityTypes\": [\"BANK_ACCOUNT\", \"ROUTING_NUMBER\", \"CREDIT_CARD\"],\n  \"threshold\": 0.5\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/v1/pii/detect",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "v1", "pii", "detect"]
        },
        "description": "Detect financial PII entities in text"
      },
      "response": []
    },
    {
      "name": "Detect PII - Trading Example",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Buy 100 shares of AAPL (ISIN: US0378331005) for portfolio P12345. Trade ID: TRD-2024-001\",\n  \"entityTypes\": [\"TICKER_SYMBOL\", \"ISIN\", \"PORTFOLIO_ID\", \"TRADE_ID\"]\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/v1/pii/detect",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "v1", "pii", "detect"]
        },
        "description": "Detect trading-related entities in text"
      },
      "response": []
    },
    {
      "name": "Detect PII - Personal Information",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Contact John Doe at john.doe@example.com or call 555-123-4567. SSN: 123-45-6789\",\n  \"entityTypes\": [\"EMAIL\", \"PHONE_NUMBER\", \"SSN\", \"NAME\"]\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/v1/pii/detect",
          "protocol": "http",
