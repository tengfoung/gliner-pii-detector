          "path": ["api", "v1", "pii", "detect"]
        },
        "description": "Detect personal information entities in text"
      },
      "response": []
    },
    {
      "name": "Detect PII - Auto-detect All Types",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"My email is alice@company.com, phone is 555-987-6543, and my SWIFT code is CHASUS33XXX\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/v1/pii/detect",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "v1", "pii", "detect"]
        },
        "description": "Detect all entity types automatically (no entityTypes specified)"
      },
      "response": []
    },
    {
      "name": "Batch Detection - Multiple Texts",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"texts\": [\n    \"Account number: 987654321, routing: 021000021\",\n    \"Email: bob@trading.com, Portfolio: P67890\",\n    \"Credit card: 5555-4444-3333-2222, ISIN: US0378331005\"\n  ],\n  \"entityTypes\": [\"BANK_ACCOUNT\", \"ROUTING_NUMBER\", \"EMAIL\", \"PORTFOLIO_ID\", \"CREDIT_CARD\", \"ISIN\"],\n  \"threshold\": 0.5\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/v1/pii/detect/batch",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "v1", "pii", "detect", "batch"]
        },
        "description": "Process multiple texts in a single batch request"
      },
      "response": []
    },
    {
      "name": "Detect PII - Complex Financial Document",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"CONFIDENTIAL TRADING REPORT\\n\\nClient: John Smith (SSN: 123-45-6789)\\nEmail: j.smith@investment.com\\nPhone: +1-555-123-4567\\n\\nAccount Details:\\n- Account Number: 1234567890\\n- Routing Number: 021000021\\n- SWIFT Code: CHASUS33XXX\\n\\nRecent Transactions:\\n1. Buy 500 AAPL (CUSIP: 037833100) - Trade ID: TRD-2024-001\\n2. Sell 200 MSFT (ISIN: US5949181045) - Trade ID: TRD-2024-002\\n\\nPayment Method: Credit Card ending in 9010\\nFull Card: 4532-1234-5678-9010\\n\\nPortfolio ID: P-12345-PREMIUM\",\n  \"threshold\": 0.4\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/v1/pii/detect",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "v1", "pii", "detect"]
        },
        "description": "Detect all entity types in a complex multi-line document with mixed PII"
      },
      "response": []
    },
    {
      "name": "Get Masking Strategies",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/api/v1/redaction/strategies",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "v1", "redaction", "strategies"]
        },
        "description": "Get available masking strategies for PII redaction"
      },
      "response": []
    },
    {
      "name": "Redact PII - FULL Strategy",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Please transfer $5000 from account 123456789 to routing number 021000021. My credit card 4532-1234-5678-9010 can be used for backup. Contact me at john.doe@example.com or 555-123-4567.\",\n  \"entityTypes\": [\"BANK_ACCOUNT\", \"ROUTING_NUMBER\", \"CREDIT_CARD\", \"EMAIL\", \"PHONE_NUMBER\"],\n  \"threshold\": 0.5,\n  \"maskCharacter\": \"*\",\n  \"maskingStrategy\": \"FULL\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/v1/redaction/redact",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "v1", "redaction", "redact"]
        },
        "description": "Redact PII with FULL masking (completely masks values with asterisks)"
      },
      "response": []
    },
    {
      "name": "Redact PII - PARTIAL Strategy",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Credit card: 4532-1234-5678-9010, Account: 987654321, Email: alice@company.com\",\n  \"maskingStrategy\": \"PARTIAL\",\n  \"maskCharacter\": \"*\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/v1/redaction/redact",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "v1", "redaction", "redact"]
        },
        "description": "Redact PII with PARTIAL masking (shows first and last few characters)"
      },
      "response": []
    },
    {
      "name": "Redact PII - HASH Strategy",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"SSN: 123-45-6789, Account: 1234567890, SWIFT: CHASUS33XXX\",\n  \"entityTypes\": [\"SSN\", \"BANK_ACCOUNT\", \"SWIFT_CODE\"],\n  \"maskingStrategy\": \"HASH\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/v1/redaction/redact",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "v1", "redaction", "redact"]
        },
        "description": "Redact PII with HASH strategy (replaces with hash values)"
      },
      "response": []
    },
    {
      "name": "Redact PII - TOKEN Strategy",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Buy 100 shares of AAPL (ISIN: US0378331005) for portfolio P12345. Credit card 4532-1234-5678-9010 on file.\",\n  \"maskingStrategy\": \"TOKEN\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/v1/redaction/redact",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "v1", "redaction", "redact"]
        },
        "description": "Redact PII with TOKEN strategy (replaces with entity type tokens like [CREDIT_CARD])"
      },
      "response": []
    },
    {
      "name": "Remask PII - Restore Original",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"redactedText\": \"Please transfer $5000 from account ********* to routing number *********. My credit card ******************* can be used for backup.\",\n  \"redactionToken\": \"RDT-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/v1/redaction/remask",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "v1", "redaction", "remask"]
        },
        "description": "Restore original PII values using the redaction token from a previous redact operation. NOTE: Replace the redactionToken value with the actual token from your redact response."
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ]
